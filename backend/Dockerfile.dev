FROM golang:1.22.12-alpine3.21

ARG GLIBC_VERSION=2.35-r1

RUN apk add --no-cache graphviz openjdk17-jdk python3

# TXL (required for Python code generation) is a glibc binary.
# Install glibc compatibility layer for Alpine and create the /lib64 symlink
# that the dynamic linker path (hardcoded in the ELF binary) expects.
RUN wget -q -O /etc/apk/keys/sgerrand.rsa.pub https://alpine-pkgs.sgerrand.com/sgerrand.rsa.pub \
 && wget -q https://github.com/sgerrand/alpine-pkg-glibc/releases/download/${GLIBC_VERSION}/glibc-${GLIBC_VERSION}.apk \
 && apk add --no-cache --force-overwrite glibc-${GLIBC_VERSION}.apk \
 && rm glibc-${GLIBC_VERSION}.apk \
 && mkdir -p /lib64 \
 && ln -sf /usr/glibc-compat/lib/ld-linux-x86-64.so.2 /lib64/ld-linux-x86-64.so.2

RUN go install github.com/air-verse/air@v1.61.7

WORKDIR /app

# go.mod and source are mounted via volumes at runtime
# Air will handle building on file changes
EXPOSE 3001
CMD ["sh", "-c", "go mod tidy && air -c .air.toml"]
