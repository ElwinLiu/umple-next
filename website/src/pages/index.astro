---
import Base from '../layouts/Base.astro'
import Hero from '../components/Hero.astro'
import FeatureCard from '../components/FeatureCard.astro'

const exampleCode = `class Student {}

class CourseSection {}

class Registration
{
  String grade;
  * -- 1 Student;
  * -- 1 CourseSection;
}`

const features = [
  {
    icon: '\u{1F517}',
    title: 'Associations',
    description: 'Define relationships between classes directly in code. Umple generates all the boilerplate for adding, removing, and maintaining referential integrity.',
  },
  {
    icon: '\u{1F504}',
    title: 'State Machines',
    description: 'Model complex behavior with state machines as first-class language constructs. Visualize them as diagrams or edit them graphically.',
  },
  {
    icon: '\u{2699}\u{FE0F}',
    title: 'Multi-Language Code Generation',
    description: 'Generate production-ready code in Java, Python, C++, or PHP from a single Umple model. The generated code is reliable and never needs manual maintenance.',
  },
  {
    icon: '\u{1F4CA}',
    title: 'UML Diagrams',
    description: 'Create class diagrams, state diagrams, and other software engineering diagrams textually. Umple renders them automatically.',
  },
  {
    icon: '\u{1F310}',
    title: 'Browser-Based Editor',
    description: 'Use UmpleOnline to model, generate code, and visualize diagrams right in your browser. No installation required.',
  },
  {
    icon: '\u{1F916}',
    title: 'AI Integration',
    description: 'Combine Umple with AI code generation: ask your AI to generate data models or state models in Umple directly from requirements.',
  },
]

const recentAdvances = [
  '2026: New versions of plugins for VSCode, and new plugin for the Zed editor',
  '2026: A language server protocol (LSP) server repository powers various IDEs',
  '2026: Umple skills repository to help AIs use Umple',
  '2026: CRUD forms generation tool with load and save capability',
  '2026: Dark mode and filtering in UmpleOnline',
  '2026: Multiple class diagram layout algorithms',
  '2025: Instance diagram generation',
  '2025: Collaborative editing',
  '2024: Editable state machine diagrams',
  '2024: Requirements embedding with req and implementsReq keywords',
  '2024: JSON generation and loading with genJson suboption',
  '2024: Python code generation',
]
---

<Base title="Umple -- Model-Oriented Programming">
  <Hero
    title="Umple -- Model-Oriented Programming"
    subtitle="Add UML abstractions like associations, attributes, and state machines directly into Java, Python, C++, and PHP. Write less code. Ship reliable software."
    primaryLink={{ href: 'https://umple-next.elwin.cc', label: 'Try Online' }}
    secondaryLink={{ href: '/download', label: 'Download' }}
  />

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">What is Umple?</h2>
      <div class="about-grid">
        <div class="about-text">
          <p>
            Umple is a <strong>modeling tool</strong> and <strong>programming language family</strong> that
            enables Model-Oriented Programming. It adds abstractions such as associations, attributes, and
            state machines to object-oriented programming languages such as Java, Python, C++ and PHP. Umple
            can also be used to create many kinds of software engineering diagrams textually.
          </p>
          <p>
            Umple creates reliable code from highly-readable abstractions. The resulting system has many fewer
            lines than if programmed in a typical programming language, since developers avoid writing
            boilerplate code. Unlike AI-generated code, the boilerplate <em>never has to be inspected or
            maintained</em>, and has been tested so it is <em>reliable</em>.
          </p>
          <p>
            <a href="https://github.com/umple/umple" target="_blank" rel="noopener noreferrer">Umple is an open source project</a>
            hosted on GitHub. The Umple compiler itself is written in Umple. Any Java, Python, C++ or PHP project
            can be adapted to use Umple.
          </p>
        </div>
        <div class="about-code">
          <h3>Example</h3>
          <pre><code set:text={exampleCode} /></pre>
          <p class="code-caption">
            Declare attributes and associations in a few lines.
            <a href="https://umple-next.elwin.cc" target="_blank" rel="noopener noreferrer">Load this in UmpleOnline</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Key Features</h2>
      <div class="features-grid">
        {features.map(f => (
          <FeatureCard icon={f.icon} title={f.title} description={f.description} />
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Links Section -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Get Started</h2>
      <div class="quicklinks-grid">
        <a href="https://umple-next.elwin.cc" class="quicklink" target="_blank" rel="noopener noreferrer">
          <span class="quicklink-icon" aria-hidden="true">{'\u{25B6}'}</span>
          <span class="quicklink-label">Try Online</span>
          <span class="quicklink-desc">Model and generate code in your browser</span>
        </a>
        <a href="/download" class="quicklink">
          <span class="quicklink-icon" aria-hidden="true">{'\u{2B07}'}</span>
          <span class="quicklink-label">Download</span>
          <span class="quicklink-desc">Command line, VS Code, Eclipse plugins</span>
        </a>
        <a href="https://manual.umple.org" class="quicklink" target="_blank" rel="noopener noreferrer">
          <span class="quicklink-icon" aria-hidden="true">{'\u{1F4D6}'}</span>
          <span class="quicklink-label">Documentation</span>
          <span class="quicklink-desc">Complete user manual with live examples</span>
        </a>
        <a href="https://github.com/umple/umple" class="quicklink" target="_blank" rel="noopener noreferrer">
          <span class="quicklink-icon" aria-hidden="true">{'\u{1F4BB}'}</span>
          <span class="quicklink-label">GitHub</span>
          <span class="quicklink-desc">Source code, issues, and contributions</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Advances Section -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Recent Advances</h2>
      <ul class="advances-list">
        {recentAdvances.map(item => (
          <li>{item}</li>
        ))}
      </ul>
      <p class="advances-footer">
        See the <a href="https://github.com/umple/umple/releases" target="_blank" rel="noopener noreferrer">release notes</a> for full details.
      </p>
    </div>
  </section>
</Base>

<style>
  /* About Section */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .about-text p {
    margin: 0 0 var(--space-md);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .about-code h3 {
    margin: 0 0 var(--space-sm);
    font-size: 1.1rem;
  }

  .code-caption {
    margin: var(--space-sm) 0 0;
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Quick Links Grid */
  .quicklinks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-md);
    max-width: 900px;
    margin: 0 auto;
  }

  .quicklink {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-xl) var(--space-lg);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .quicklink:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .quicklink-icon {
    font-size: 2rem;
    margin-bottom: var(--space-sm);
  }

  .quicklink-label {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-xs);
  }

  .quicklink-desc {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  /* Recent Advances */
  .advances-list {
    max-width: 700px;
    margin: 0 auto var(--space-lg);
    padding-left: var(--space-lg);
  }

  .advances-list li {
    margin-bottom: var(--space-xs);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .advances-footer {
    text-align: center;
    font-size: 0.95rem;
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .quicklinks-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
