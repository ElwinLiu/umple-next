{
  "name": "umpleonline-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ai:live": "AI_LIVE_TESTS=1 vitest run src/ai/__tests__/agent-loop.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:live": "PLAYWRIGHT_LIVE_BACKEND=1 playwright test tests/e2e/live-backend.spec.ts tests/e2e/live-generate.spec.ts",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:typecheck": "tsc -p tsconfig.playwright.json --noEmit"
  },
